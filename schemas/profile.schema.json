{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "version", "componentTypes", "commands", "capabilities", "templateVariables"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "version": { "type": "integer", "minimum": 1 },
    "componentTypes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["server", "admin", "client"] }
    },
    "commands": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "boolean" }
        ]
      }
    },
    "templateVariables": {
      "type": "object",
      "propertyNames": { "pattern": "^[A-Z0-9_]+$" },
      "additionalProperties": { "type": "string" }
    }
  }
}
